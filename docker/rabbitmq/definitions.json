{
  "rabbit_version": "3.13.0",
  "users": [
    {
      "name": "gridtokenx",
      "password_hash": "rabbitmq_secret_2025",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": "administrator"
    }
  ],
  "vhosts": [
    {
      "name": "/"
    }
  ],
  "permissions": [
    {
      "user": "gridtokenx",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "topic_permissions": [],
  "parameters": [],
  "global_parameters": [
    {
      "name": "cluster_name",
      "value": "gridtokenx-rabbitmq-cluster"
    }
  ],
  "policies": [
    {
      "vhost": "/",
      "name": "ha-all",
      "pattern": ".*",
      "apply-to": "all",
      "definition": {
        "ha-mode": "all",
        "ha-sync-mode": "automatic",
        "ha-sync-batch-size": 100
      },
      "priority": 0
    },
    {
      "vhost": "/",
      "name": "dlx-policy",
      "pattern": ".*",
      "apply-to": "queues",
      "definition": {
        "dead-letter-exchange": "dlx.exchange"
      },
      "priority": 1
    }
  ],
  "queues": [
    {
      "name": "email.notifications",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "password.resets",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "settlement.retries",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-max-priority": 10
      }
    },
    {
      "name": "meter.validation",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "batch.jobs",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "webhook.deliveries",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "exchanges": [
    {
      "name": "notifications",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "trading",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "oracle",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "scheduler",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "integrations",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "dlx.exchange",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "notifications",
      "vhost": "/",
      "destination": "email.notifications",
      "destination_type": "queue",
      "routing_key": "email.*",
      "arguments": {}
    },
    {
      "source": "trading",
      "vhost": "/",
      "destination": "settlement.retries",
      "destination_type": "queue",
      "routing_key": "settlement.retry",
      "arguments": {}
    },
    {
      "source": "oracle",
      "vhost": "/",
      "destination": "meter.validation",
      "destination_type": "queue",
      "routing_key": "meter.validate",
      "arguments": {}
    },
    {
      "source": "scheduler",
      "vhost": "/",
      "destination": "batch.jobs",
      "destination_type": "queue",
      "routing_key": "batch.*",
      "arguments": {}
    },
    {
      "source": "integrations",
      "vhost": "/",
      "destination": "webhook.deliveries",
      "destination_type": "queue",
      "routing_key": "webhook.*",
      "arguments": {}
    }
  ]
}
