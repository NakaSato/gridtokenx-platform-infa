# General
TZ=UTC

# Postgres
POSTGRES_DB=gridtokenx
POSTGRES_USER=gridtokenx_user
POSTGRES_PASSWORD=gridtokenx_password

# Redis
REDIS_PORT=6379

# InfluxDB
INFLUXDB_PORT=8086
INFLUXDB_USER=gridtokenx_user
INFLUXDB_PASSWORD=gridtokenx_password
INFLUXDB_ORG=gridtokenx
INFLUXDB_BUCKET=energy_readings
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_URL=http://localhost:8086

# API Gateway
APIGATEWAY_PORT=4000
PORT=4000
SERVER_HOST=0.0.0.0
SERVER_PORT=4000
ENVIRONMENT=development
RUST_LOG=info
LOG_LEVEL=info
LOG_FORMAT=json
AUDIT_LOG_ENABLED=true
TEST_MODE=false

# Database / Redis / InfluxDB within App
MAX_CONNECTIONS=50
MIN_CONNECTIONS=5
DATABASE_MAX_CONNECTIONS=50
DATABASE_MIN_CONNECTIONS=5
REDIS_POOL_SIZE=20
REDIS_MAX_CONNECTIONS=20
REDIS_CONNECTION_TIMEOUT=5
REDIS_COMMAND_TIMEOUT=3
REQUEST_TIMEOUT=30

# Smart Meter Simulator Integration
SIMULATOR_URL=http://127.0.0.1:8082

# Solana Blockchain
