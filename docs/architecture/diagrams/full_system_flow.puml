@startuml full_system_flow
' ============================================================================
' GridTokenX Platform - Complete System Flow Diagram
' ============================================================================

skinparam dpi 300
skinparam defaultFontSize 12
skinparam defaultFontName Arial
skinparam backgroundColor #FFFFFF

title **GridTokenX Platform - Complete System Flow**
footer P2P Energy Trading on Solana | 2026

' ============================================================================
' PARTICIPANTS
' ============================================================================

' Physical Layer
participant "Solar Panel\nArray" as solar
participant "Smart Meter\nSimulator" as meter
participant "Home Load\nConsumer" as load

' Frontend Layer
participant "Trading Platform\n(Next.js)" as ui_trading
participant "Smart Meter UI\n(React)" as ui_meter
participant "Solana Wallet\n(Phantom)" as wallet

' API Gateway Layer
participant "Nginx\nLB" as nginx
participant "API Gateway\n(Rust/Axum)" as api
participant "IAM Service" as iam
participant "Trading Service" as trading_svc
participant "Oracle Bridge" as oracle

' Data Layer
participant "PostgreSQL" as pg
participant "Redis" as redis
participant "InfluxDB" as influx

' Event Streaming
participant "Kafka" as kafka

' Blockchain Layer
participant "Solana\nValidator" as solana
participant "Registry\nProgram" as registry
participant "Energy Token\nProgram" as energy_token
participant "Trading\nProgram" as trading_prog
participant "Oracle\nProgram" as oracle_prog
participant "SPL Token\nProgram" as spl

' Monitoring
participant "Prometheus" as prometheus
participant "Grafana" as grafana

' External
participant "Pyth Network" as pyth_oracle
participant "Email Service" as email_service

' ============================================================================
' FLOW 1: ENERGY GENERATION & TOKENIZATION
' ============================================================================
solar -> meter: DC/AC Power + Telemetry
activate meter
meter -> ui_meter: Real-time readings (WS)
activate ui_meter
meter -> oracle: Signed readings (Ed25519)
activate oracle
oracle -> oracle: Verify & Validate
oracle -> kafka: Publish event
activate kafka
oracle -> influx: Store time-series
activate influx
kafka -> api: Consume reading
activate api
api -> redis: Cache latest
activate redis
api -> api: Calculate kWh to GRID
api -> energy_token: Mint GRID tokens
activate energy_token
energy_token -> spl: Mint (CPI)
activate spl
spl -> energy_token: Minted
deactivate spl
energy_token -> api: Confirmation
deactivate energy_token
api -> pg: Record transaction
activate pg
api -> meter: Token ID
deactivate meter
deactivate ui_meter
deactivate oracle
deactivate kafka
deactivate influx
deactivate redis
deactivate pg

' ============================================================================
' FLOW 2: USER REGISTRATION
' ============================================================================
ui_trading -> ui_trading: User registers
activate ui_trading
ui_trading -> iam: POST /register
activate iam
iam -> pg: Check email
iam -> iam: Hash password (Argon2)
iam -> pg: Create user
iam -> redis: Session token
iam -> email_service: Verification email
activate email_service
email_service --> ui_trading: Email sent
deactivate email_service
ui_trading -> wallet: Connect wallet
activate wallet
wallet -> ui_trading: Wallet address
deactivate wallet
ui_trading -> iam: Link wallet
iam -> registry: Register PDA
activate registry
registry -> solana: Submit transaction
activate solana
solana -> registry: Confirmed
deactivate solana
registry -> iam: PDA address
deactivate registry
iam -> pg: Store mapping
iam -> ui_trading: Registration complete
deactivate iam
deactivate ui_trading

' ============================================================================
' FLOW 3: P2P TRADING
' ============================================================================
ui_trading -> ui_trading: Create sell order
activate ui_trading
ui_trading -> api: POST /orders
activate api
api -> iam: Validate token
activate iam
iam -> redis: Verify session
activate redis
redis -> iam: Valid
deactivate redis
iam -> api: Auth OK
deactivate iam
api -> trading_svc: Forward (gRPC)
activate trading_svc
trading_svc -> pg: Store order
activate pg
trading_svc -> trading_svc: Add to order book
trading_svc -> api: Acknowledged
deactivate trading_svc
deactivate pg
api -> ui_trading: Order created
deactivate api
deactivate ui_trading

trading_svc -> trading_svc: Match orders
activate trading_svc
trading_svc -> trading_prog: Lock escrow
activate trading_prog
trading_prog -> spl: Transfer to PDA
activate spl
spl -> trading_prog: Escrowed
deactivate spl
trading_prog -> trading_svc: Locked
deactivate trading_prog
trading_svc -> api: Match event
activate api
api -> ui_trading: Notify (WS)
deactivate api
deactivate trading_svc
deactivate ui_trading

' ============================================================================
' FLOW 4: ATOMIC SETTLEMENT
' ============================================================================
trading_svc -> trading_prog: Execute settlement
activate trading_svc
activate trading_prog
trading_prog -> trading_prog: Validate conditions
trading_prog -> oracle_prog: Get price
activate oracle_prog
oracle_prog -> pyth_oracle: Fetch price
activate pyth_oracle
pyth_oracle -> oracle_prog: Price data
deactivate pyth_oracle
oracle_prog -> trading_prog: Verified
deactivate oracle_prog
trading_prog -> spl: Transfer GRID
activate spl
spl -> trading_prog: Done
deactivate spl
trading_prog -> spl: Transfer USDC
spl -> trading_prog: Done
spl -> trading_prog: Done
trading_prog -> trading_prog: Deduct fees
trading_prog -> trading_prog: Emit event
trading_prog -> trading_svc: Confirmed
deactivate trading_prog
trading_svc -> pg: Update status
activate pg
trading_svc -> redis: Invalidate cache
activate redis
trading_svc -> ui_trading: Complete (WS)
activate ui_trading
deactivate trading_svc
deactivate pg
deactivate redis
deactivate ui_trading

' ============================================================================
' FLOW 5: MONITORING
' ============================================================================
prometheus -> api: Scrape /metrics
activate api
api -> prometheus: Metrics
deactivate api
prometheus -> solana: Scrape stats
activate solana
solana -> prometheus: Validator stats
deactivate solana
prometheus -> pg: Query DB
activate pg
pg -> prometheus: DB metrics
deactivate pg
grafana -> prometheus: PromQL query
activate grafana
prometheus -> grafana: Time-series data
deactivate prometheus
grafana -> grafana: Render dashboards
deactivate grafana

' ============================================================================
' NOTES
' ============================================================================
note right
  **Protocols:**
  - HTTPS/WSS: Client to API
  - gRPC: Microservices
  - JSON-RPC: Solana
  - Kafka: Events
  - PostgreSQL/RESP: DB/Cache
end note

note left
  **Security:**
  - Ed25519: Meter signatures
  - Argon2: Password hashing
  - JWT: Sessions
  - PDA: Blockchain identities
end note

note right of trading_prog
  **Atomic Settlement**
  All-or-nothing execution
  - Fails if any step fails
  - No partial state changes
  - Guaranteed finality
end note

@enduml
