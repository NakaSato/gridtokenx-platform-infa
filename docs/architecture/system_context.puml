@startuml system_context
' ============================================================================
' GridTokenX Platform - System Context Diagram
' ============================================================================

skinparam dpi 300
skinparam defaultFontSize 14
skinparam defaultFontName Arial
skinparam backgroundColor #FFFFFF

title **GridTokenX Platform - System Context Diagram**
footer P2P Energy Trading on Solana | 2026

' ============================================================================
' EXTERNAL ACTORS
' ============================================================================

actor "Prosumer\n(Household with Solar)" as prosumer
actor "Consumer\n(Household without Solar)" as consumer
actor "Platform Admin" as admin

rectangle "Solar Inverter\n(IoT Device)" as solar_inverter
rectangle "Pyth Network\n(Price Oracle)" as pyth_network
rectangle "Email Provider\n(SMTP)" as email_provider

' ============================================================================
' GRIDTOKENX PLATFORM
' ============================================================================

rectangle "GridTokenX Platform" {
    rectangle "Trading Platform\n(Next.js)" as trading_platform
    rectangle "API Gateway\n(Rust/Axum)" as api_gateway
    rectangle "Smart Meter\nSimulator\n(Python)" as smartmeter_sim
    
    rectangle "Solana Blockchain" {
        database "SPL Tokens\n(GRID + USDC)" as spl_tokens
        rectangle "Smart Contracts\n(Anchor)" as smart_contracts
    }
    
    database "PostgreSQL" as postgres
    database "Redis" as redis
    database "InfluxDB" as influxdb
    queue "Kafka" as kafka
}

rectangle "Prometheus +\nGrafana" as monitoring
rectangle "Solana Validator" as solana_validator

' ============================================================================
' RELATIONSHIPS
' ============================================================================

' Users
prosumer -> trading_platform: "Sell energy"
consumer -> trading_platform: "Buy energy"
admin -> trading_platform: "Manage"

' Frontend to Backend
trading_platform -> api_gateway: "REST API"
trading_platform -> smart_contracts: "Wallet TX (JSON-RPC)"

' Smart Meter
solar_inverter -> smartmeter_sim: "Telemetry"
smartmeter_sim -> api_gateway: "POST /readings"
smartmeter_sim -> kafka: "Stream events"

' API Gateway
api_gateway -> postgres: "CRUD"
api_gateway -> redis: "Cache/Session"
api_gateway -> influxdb: "Time-series"
api_gateway -> kafka: "Consume"
api_gateway -> smart_contracts: "Execute TX"
api_gateway -> email_provider: "SMTP"
api_gateway -> pyth_network: "Price API"

' Blockchain
smart_contracts -> spl_tokens: "Mint/Transfer"
smart_contracts -> solana_validator: "Submit TX"

' Monitoring
monitoring -> api_gateway: "Scrape /metrics"
monitoring -> postgres: "Stats"
monitoring -> kafka: "Lag"

' ============================================================================
' NOTES
' ============================================================================

note bottom
  **Technology Stack:**
  Frontend: Next.js, TypeScript
  Backend: Rust, Axum, gRPC
  Blockchain: Solana, Anchor
  Databases: PostgreSQL, Redis, InfluxDB
  Streaming: Apache Kafka
end note

note right of smart_contracts
  **Anchor Programs:**
  - Registry (Identity)
  - Energy Token (GRID)
  - Trading (P2P)
  - Oracle (Prices)
  - Governance (DAO)
end note

@enduml
